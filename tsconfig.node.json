{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "./vite.config.ts",
    "./scripts/**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    "./dist"
  ]
}