} from 'lucide-react'

const Home = () => {
  // Mock data για τις κατηγορίες
  const categories = [
    { slug: 'nuts', name: 'Ξηροί Καρποί' },
    { slug: 'dried-fruits', name: 'Αποξηραμένα Φρούτα' },
    { slug: 'chocolates', name: 'Σοκολατάκια' },
    { slug: 'coffee', name: 'Καφές' },
    { slug: 'juices', name: 'Χυμοί & Smoothies' }
  ]

  const getProductsByCategory = (slug) => {
    // Mock function - επιστρέφει random αριθμό προϊόντων
    const counts = { 'nuts': 25, 'dried-fruits': 18, 'chocolates': 12, 'coffee': 8, 'juices': 15 }
    return Array(counts[slug] || 10).fill({})
  }

  // Mock HeroSlider component
  const HeroSlider = () => {
    const [currentSlide, setCurrentSlide] = useState(0)
    
    const slides = [
      {
        image: 'https://images.unsplash.com/photo-1623428187969-5da2dcea5ebf?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80',
        title: 'Ξηροί Καρποί Premium',
        subtitle: 'Η καλύτερη ποιότητα για την υγεία σας'
      },
      {
        image: 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80',
        title: 'Αποξηραμένα Φρούτα',
        subtitle: 'Φυσική γλυκιά απόλαυση'
      }
    ]

    useEffect(() => {
      const timer = setInterval(() => {
        setCurrentSlide((prev) => (prev + 1) % slides.length)
      }, 5000)
      return () => clearInterval(timer)
    }, [slides.length])

    return (
      <div className="relative h-screen overflow-hidden">
        {slides.map((slide, index) => (
          <motion.div
            key={index}
            initial={{ opacity: 0 }}
            animate={{ opacity: index === currentSlide ? 1 : 0 }}
            transition={{ duration: 1 }}
            className="absolute inset-0"
          >
            <img
              src={slide.image}
              alt={slide.title}
              className="w-full h-full object-cover"
            />
            <div className="absolute inset-0 bg-gradient-to-r from-black/60 to-black/20" />
            <div className="absolute inset-0 flex items-center justify-center text-white">
              <div className="text-center">
                <motion.h1
                  initial={{ y: 50, opacity: 0 }}
                  animate={{ y: 0, opacity: 1 }}
                  transition={{ delay: 0.5 }}
                  className="text-5xl md:text-7xl font-bold mb-4"
                >
                  {slide.title}
                </motion.h1>
                <motion.p
                  initial={{ y: 30, opacity: 0 }}
                  animate={{ y: 0, opacity: 1 }}
                  transition={{ delay: 0.7 }}
                  className="text-xl md:text-2xl"
                >
                  {slide.subtitle}
                </motion.p>
              </div>
            </div>
          </motion.div>
        ))}
      </div>
